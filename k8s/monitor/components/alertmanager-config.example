global:
  resolve_timeout: 5m
  smtp_smarthost: 'smtp.gmail.com:587'
  smtp_from: EMAIL_HERE
  smtp_auth_username: EMAIL_HERE
  smtp_auth_password: PASSWORD_HERE
  smtp_require_tls: true

route:
  group_by: ['job', 'alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  receiver: 'email-receiver'
  routes:
    - match:
        alertname: Watchdog
      receiver: 'null'

receivers:
- name: 'null'
- name: 'email-receiver'
  email_configs:
  - to: EMAIL_HERE
    send_resolved: true